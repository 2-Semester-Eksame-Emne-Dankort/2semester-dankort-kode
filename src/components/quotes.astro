<style>

.quotes {
  padding: 4rem 1rem;
}

.quotes-slider {
  display: flex;
  gap: 2rem;

  overflow-x: auto;

  scroll-snap-type: x mandatory;

  padding-bottom: 1rem;

  scrollbar-width: none;
}

.quotes-slider::-webkit-scrollbar {
  display: none;
}

.quote-card {
  width: 360px;

  flex-shrink: 0;

  background: #d9d9d9;

  border-radius: 40px;

  padding: 1.2rem;

  scroll-snap-align: center;
}

.quote-image {
  width: 100%;

  height: 320px;

  object-fit: cover;

  border-radius: 22px;

  display: block;
}

.quote-content {
  text-align: center;

  padding: 1.8rem 1rem 1rem;
}

.quote-text {
  font-size: 1.5rem;

  font-weight: 700;

  line-height: 1.5;

  color: var(--the-black);

  margin-bottom: 1rem;
}

.quote-author {
  font-size: 1rem;

  color: #7a7a7a;

  font-style: italic;
}

</style>

<script>

//Finder slider-elementet
  const slider = document.querySelector('.quotes-slider');

  // Tjekker om slideren findes
  if (slider) {

    //Kør noget igen og igen efter et bestemt tidsinterval (3000ms = 3sek)
    setInterval(() => {

      //Scroller slideren mod højre.
      slider.scrollBy({
        left: 392,
        behavior: 'smooth'
      });

      // Reset to start
      if (
        slider.scrollLeft + slider.clientWidth >=
        slider.scrollWidth - 10
      ) {
        slider.scrollTo({
          left: 0,
          behavior: 'smooth'
        });
      }

    }, 3000);

  }

</script>