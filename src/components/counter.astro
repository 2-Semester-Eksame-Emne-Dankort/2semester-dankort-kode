---
const endpoint = "https://ixghczwghjowmllzbjuk.supabase.co/rest/v1/oermaerketsiden-taeller?select=*&order=year.asc"; //Define the API endpoint URL, with query parameters to select all data and order by year ascending.
const options = {
  headers: {
    apikey: "sb_publishable_LrHsJDkISlXic1PhUDY__Q_g7qLlqpL",
  },
}

const years = await fetch(endpoint, options).then(response=>response.json()); // Fetch data from Supabase and convert it into JavaScript data
const activeYear = years[2];
//@ts-nocheck
---

<div class="counter-card">
  <div class="year-tabs"> 
    {years.map((yearData: any) => ( //Loop through the years data and create a button for each year, For each year object, the code generates a button dynamically.
      <button
        class={`year-tab ${yearData.year === activeYear.year ? "active" : ""}`} //If this button’s year is the same as the active year, add the class active. Otherwise add nothing.
        data-year={yearData.year} //Add a data attribute to the button with the year value, so we can access it in the click event listener.
      >
        {yearData.year}
      </button>
    ))}
  </div>

  <div class="top">
    <div>
      <h2 id="current-year">{activeYear.year}</h2>
      <p>Estimeret donation indtil videre</p>
      <h1 id="donation-amount">{activeYear.donation_amount} KR</h1>
    </div>

    <div class="top-right">
      2,3 millioner danskere hjælper naturen gennem Dankort
    </div>
  </div>

  <div class="progress-bar">
    <div
      class="progress"
      id="progress-line"
      style={`width:${activeYear.progress_percent}%`}
    ></div>
  </div>

  <div class="bottom-cards">
    <div class="info-card">
      <span>Det svarer til</span>
      <h3 id="area-val">{activeYear.area_number} m²</h3>
      <p>Naturområde beskyttet</p>
    </div>

    <div class="info-card">
      <span>Eller ca.</span>
      <h3 id="co2-val">{activeYear.co2_amount} Tons CO₂</h3>
      <p>Optaget årligt</p>
    </div>

    <div class="info-card">
      <span>Eller ca.</span>
      <h3 id="species-val">{activeYear.animal_species}</h3>
      <p>Dyrearter hjulpet</p>
    </div>
  </div>
</div>

<script define:vars={{ years }}> //This is Astro-specific syntax and makes the years data available in the script, so we can use it to update the content when a year tab is clicked.
  //Without this, the browser script would not know what years is.
  const tabs = document.querySelectorAll(".year-tab"); //Select all the year tab buttons, so we can add click event listeners to them.

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const selectedYear = years.find(
        (item) => item.year == tab.dataset.year
      ); //Find the year data that matches the year of the clicked button, using the data-year attribute.

      tabs.forEach((tabButton) => tabButton.classList.remove("active"));
      tab.classList.add("active"); //Remove the active class from all buttons, then add it to the clicked button.

      document.querySelector("#current-year").textContent =
        selectedYear.year; //Update the content of the elements with the data from the selected year.

      document.querySelector("#donation-amount").textContent =
        selectedYear.donation_amount + " KR"; 

      document.querySelector("#area-val").textContent =
        selectedYear.area_number + " m²";

      document.querySelector("#co2-val").textContent =
        selectedYear.co2_amount + " Tons CO₂";

      document.querySelector("#species-val").textContent =
        selectedYear.animal_species; 

      document.querySelector("#progress-line").style.width =
        selectedYear.progress_percent + "%"; //Update the width of the progress line based on the selected year's progress percent.
    });
  });
</script>

<style>
  .counter-card {
    position: relative;
    background: var(--the-blue);
    color: white;
    padding: 24px;
    border-radius: 24px;
    max-width: 800px;
    margin: 60px auto 24px;
    font-family: var(--font);
    max-width: 90%;
    margin-bottom: 5rem;
  }


  .year-tabs {
    display: flex;
    gap: 6px;
    position: absolute;
    top: -32px;
    left: 0;
    padding-left: 18px;
  }

  .year-tab {
    border: none;
    background: var(--the-lightblue);
    color: white;
    font-weight: 700;
    font-size: 20px;
    padding: 10px 28px 10px 18px;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    margin-top: -11px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.04);
    cursor: pointer;
    font-family: inherit;
  }

  .year-tab:not(.active) {
    background: var(--the-lightblue);
    color: var(--the-black);
  }

  .year-tab.active {
    background: var(--the-blue);
    color: white;
    z-index: 3;
  }

  .top {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  h1 {
    font-size: 32px;
    margin: 14px 0;
    font-weight: 400;
    font-feature-settings: "lnum";
  }

  h2 {
    font-size: 28px;
    margin: 0;
      font-feature-settings: "lnum";
  }

  .top-right {
    max-width: 250px;
    font-size: 14px;
    font-weight: 600;
    margin-top: 12px;
  }

  .progress-bar {
    width: 100%;
    height: 10px;
    background: white;
    border-radius: 999px;
    margin: 40px 0;
    overflow: hidden;
  }

  .progress {
    height: 100%;
    background: var(--the-lightblue);
    border-radius: 999px;
    transition: width 0.35s ease;
  }

  .bottom-cards {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .info-card {
    background: white;
    color: black;
    padding: 14px;
    border-radius: 16px;
    flex: 1;
  }

  .info-card h3 {
    font-size: 22px;
    margin: 8px 0;
      font-feature-settings: "lnum";
  }

  .info-card p,
  .info-card span {
    color: #555;
  }

  @media (min-width: 900px) {
    .counter-card {
      max-width: 1100px;
      padding: 36px;
      margin-bottom: 5rem;
    }

    .top {
      flex-direction: row;
      justify-content: space-between;
      gap: 30px;
    }

    .top-right {
      font-size: 16px;
    }

    .bottom-cards {
      flex-direction: row;
      gap: 20px;
    }

    h1 {
      font-size: 60px;
    }
  }
</style>