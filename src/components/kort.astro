</style>



<script>


 // 1. Find alle clickable map points. Så circles med klassen "map-point" danner et array af elementer, som vi kan arbejde med. 
  const circles = document.querySelectorAll(".map-point");


  //Loop through every circle
  circles.forEach(circle => {

    circle.style.cursor = "pointer";

    //4. Add click event
    circle.addEventListener("click", () => {
 
      const popupId = "popup-" + circle.id;

      const popup = document.getElementById(popupId);

      //Find the popup element
      if (popup) {
        popup.showPopover();
      }

    });

  });

</script>