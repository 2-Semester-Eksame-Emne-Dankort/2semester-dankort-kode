---
import Button from "./button.astro";
---
<section class="hero">
  <div class="hero-content">
    <h1>BETAL MED DANKORT.</h1>
    <p>KORTET DET GIVER TILBAGE</p>

    <Button text="FÅ DANKORT" link="/" />
  </div>
</section>

<style>
  .hero {
    min-height: 420px;
    background: url("/Img/dankort-hero.webp") center/cover no-repeat;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2.2rem 1.2rem;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .hero-content {
    max-width: 100%;
    z-index: 2;
    margin-top: 60px;

  }

  .hero h1 {
    font-size: 1.7rem;
    line-height: 1.1;
    margin: 0 0 1rem;
    font-weight: 900;
    color: var(--the-black);
  }

  .hero p {
    font-size: 1rem;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
    color: #111;
  }


  @media (min-width: 900px) {
    .hero {
      height: 700px;
      flex-direction: row;
      align-items: center;
      padding: 4rem 6rem;
      min-height: unset;
    }
    .hero-content {
      max-width: 560px;
    }
    .hero h1 {
      font-size: 3rem;
      margin-bottom: 1.5rem;
    }
    .hero p {
      font-size: 1.4rem;
      margin-bottom: 2.5rem;
    }
  }
</style>

