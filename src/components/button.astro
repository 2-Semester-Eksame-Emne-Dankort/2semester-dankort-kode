---
// Vi tager imod 'text' og 'link' som indstillinger (props)
const { text, link } = Astro.props;
---

<a href={link} class="btn-outline">
  {text}
</a>

<style>
  .btn-outline {
    display: inline-block;
    width: auto;
    max-width: max-content;
    font-family: 'Railway', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: white;
    background-color: var(--the-red);
    padding: 10px 32px;
    border-radius: 50px;
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
  }

  .btn-outline:hover {
    background-color: #BB1018;
    color: white;
    transform: translateY(-2px);
  }

  @media (min-width: 900px) {
    .btn-outline {
      padding: 14px 45px;
      font-size: 1rem;
    }
  }
</style>